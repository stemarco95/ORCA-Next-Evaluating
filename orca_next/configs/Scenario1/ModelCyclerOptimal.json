{
    "mode": "step-based",
    "max_steps": 75000,
    "monitor_config_path": "configs/Scenario1/monitoring.json",
    "monitor_title": "Scenario1-ModelCyclerOptimal",
    "modules": [
        {
            "id": "model_cycler",
            "type": "ModelCycler",
            "inputs": ["utility"],
            "outputs": ["model_selection"],
            "cycle": 160,
            "config": {
                "models": [
                    "speed_14.0",
                    "speed_13.5",
                    "speed_13.0",
                    "speed_12.5",
                    "speed_12.0",
                    "speed_11.5",
                    "speed_11.0", 
                    "speed_10.5",
                    "speed_10.0",
                    "speed_9.5",
                    "speed_9.0", 
                    "speed_8.5",
                    "speed_8.0",
                    "speed_7.5",
                    "speed_7.0", 
                    "speed_6.5",
                    "speed_6.0",
                    "speed_5.5",
                    "speed_5.0",
                    "speed_4.5",
                    "speed_4.0"
                ],
                "acceptance_threshold": 0.9,
                "initial_model": "speed_7.0"
            }
        },
        {
            "id": "model_provider",
            "type": "ModelProvider",
            "inputs": ["model_selection"],
            "outputs": ["model"],
            "cycle": 1,
            "config": {
                "initial_model": "speed_7.0",
                "library_path": "configs/model_library.json"
            }
        },
        {
            "id": "disturbance_generator",
            "type": "DisturbanceGenerator",
            "inputs": [],
            "outputs": ["disturbance"],
            "cycle": 1,
            "config": {
                "target_parameter": "other_speed",
                "initial_value": 7.0,
                "disturbances": "configs/Scenario1/disturbance_schedule.json"
            }
        },
        {
            "id": "actor",
            "type": "Actor",
            "inputs": ["model","observation"],
            "outputs": ["raw_action"],
            "cycle": 1,
            "config": {}
        },
        {
            "id": "environment",
            "type": "Environment",
            "is_env": true,
            "inputs": ["safe_action", "disturbance"],
            "outputs": ["observation"],
            "cycle": 1, 
            "config": {
                "randomize_speed": false,
                "render": false
            }
        },
        {
            "id": "shield",
            "type": "Shield",
            "inputs": ["raw_action", "observation"],
            "outputs": ["safe_action"],
            "cycle": 1,
            "config": {
                "enabled": false
            }
        }
    ]
}